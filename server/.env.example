# Copy this file to .env and fill in real values. Never commit the real .env.

NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/gotogether

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_REFRESH_EXPIRES=30d
COOKIE_REFRESH_NAME=gotogether_refresh_token

# In production, if the frontend and API are on different domains (e.g. a
# Vercel frontend calling a Render API), leave this unset to default to
# "none" (required for cross-site cookies over HTTPS). Only set this to
# "strict" or "lax" if the frontend and API share the exact same domain.
# COOKIE_SAME_SITE=none

# OTP
OTP_EXPIRY_MINUTES=10

# Cloudinary (avatar / vehicle document uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (SMTP) — used to send OTP / password-reset emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM="GoTogether <no-reply@gotogether.app>"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Admin bootstrap (used only by `npm run seed` — creates/promotes this
# account to role "admin" so you can access the Admin Dashboard)
ADMIN_NAME=GoTogether Admin
ADMIN_EMAIL=admin@gotogether.app
ADMIN_PHONE=+910000000000
ADMIN_PASSWORD=Admin@12345
